{
  "name": "sql-mcp",
  "version": "1.0.0",
  "description": "Production-grade MCP server for multi-database SQL management with natural language querying",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sql-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:ui": "node esbuild.config.js",
    "build:all": "npm run build && npm run build:ui",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "npm run build && mocha --require test/setup.js 'test/**/*.test.js'",
    "test:integration": "npm run build && mocha --require test/setup.js 'test/integration/**/*.test.js' --timeout 60000",
    "test:unit": "npm run build && mocha --require test/setup.js 'test/unit/**/*.test.js'",
    "test:watch": "npm test -- --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "sql",
    "database",
    "postgresql",
    "mysql",
    "sqlite",
    "mssql",
    "oracle",
    "mariadb",
    "natural-language",
    "ai",
    "llm"
  ],
  "author": "vk",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@modelcontextprotocol/ext-apps": "^1.3.1",
    "zod": "^3.24.0",
    "pg": "^8.13.0",
    "mysql2": "^3.12.0",
    "better-sqlite3": "^11.7.0",
    "mssql": "^11.0.0",
    "mariadb": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/mssql": "^9.1.0",
    "typescript": "^5.7.0",
    "esbuild": "^0.24.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "mocha": "^11.0.0",
    "chai": "^5.1.0",
    "@types/mocha": "^10.0.0",
    "@types/chai": "^5.0.0",
    "ts-node": "^10.9.0",
    "testcontainers": "^10.16.0"
  },
  "optionalDependencies": {
    "oracledb": "^6.7.0"
  }
}
