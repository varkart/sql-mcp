{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./test-dist",
    "rootDir": "./test",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./dist/*"]
    }
  },
  "include": ["test/**/*.ts"],
  "exclude": ["node_modules", "dist", "test/setup.js", "test/e2e/**/*.ts"]
}
